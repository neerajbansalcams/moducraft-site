{
  "name": "moducraft-website",
  "version": "1.0.0",
  "description": "Moducraft - Custom Modular Furniture Website & E-commerce Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && npm start",
    "test": "concurrently \"npm run test:frontend\" \"npm run test:backend\"",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "lint": "concurrently \"npm run lint:frontend\" \"npm run lint:backend\"",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint"
  },
  "dependencies": {
    "concurrently": "^8.0.0"
  },
  "devDependencies": {},
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "keywords": [
    "furniture",
    "modular",
    "customizable",
    "e-commerce",
    "jaipur"
  ],
  "author": "Moducraft Team",
  "license": "MIT"
}
